# Copy this file to .env and fill in values.

# Django
DJANGO_SECRET_KEY=REPLACE_ME
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (container)
POSTGRES_DB=cinereserve
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres456

# Used by Django (inside the web container)
DATABASE_URL=postgresql://postgres:postgres456@db:5432/cinereserve

# Redis (container)
REDIS_URL=redis://redis:6379/0

# Optional: Postgres port exposed on the host for pgAdmin
POSTGRES_HOST_PORT=5434

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Email (dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@cinereserve.local
